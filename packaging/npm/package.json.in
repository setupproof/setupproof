{
  "name": "setupproof",
  "version": "__VERSION__",
  "description": "Run README setup commands from a clean checkout before contributors copy them.",
  "license": "Apache-2.0",
  "homepage": "https://setupproof.github.io/setupproof/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/setupproof/setupproof.git"
  },
  "bugs": {
    "url": "https://github.com/setupproof/setupproof/issues"
  },
  "keywords": [
    "readme",
    "quickstart",
    "ci",
    "github-actions",
    "documentation",
    "markdown",
    "setup",
    "testing",
    "developer-tools"
  ],
  "bin": {
    "setupproof": "bin/setupproof"
  },
  "files": [
    "bin/",
    "vendor/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public"
  }
}
